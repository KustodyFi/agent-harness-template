# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Agent (per-user, local copy)
/.agent/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
*.pem
*.key

# Build
dist/
build/
*.egg-info/

# Evidence (root-level only — task evidence in .cowork/tasks/ must be tracked)
/evidence/

# Development tracking (local only — NOT shipped with template)
# Task folders are created per-project, not part of the template
.cowork/tasks/[0-9]*/
# Round-specific review prompts are dev artifacts
.cowork/prompts/r[0-9]*_*.md
